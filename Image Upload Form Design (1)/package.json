{
  "name": "ietm-hotspot-editor",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "Vanilla JS IETM hotspot editor - draws clickable regions on technical manual figures",
  "scripts": {
    "dev": "node launcher.js",
    "build:exe": "esbuild launcher.js --bundle --platform=node --format=cjs --outfile=dist-bundle/app.cjs --external:tesseract.js --external:fsevents && pkg dist-bundle/app.cjs --targets node18-win-x64 --output ietm-hotspot-editor.exe",
    "build:dist": "npm run build:exe && node build-dist.js"
  },
  "pkg": {
    "targets": ["node18-win-x64"],
    "scripts": ["launcher.js", "server/**/*.js"],
    "assets": [
      "public/**/*",
      "bin/**/*",
      "eng.traineddata",
      "node_modules/tesseract.js/**/*",
      "node_modules/tesseract.js-core/**/*",
      "node_modules/@xmldom/**/*",
      "node_modules/express/**/*",
      "node_modules/cors/**/*",
      "node_modules/archiver/**/*",
      "node_modules/open/**/*"
    ]
  },
  "dependencies": {
    "@xmldom/xmldom": "^0.9.5",
    "archiver": "^7.0.1",
    "cors": "^2.8.5",
    "express": "^4.21.0",
    "open": "^11.0.0",
    "tesseract.js": "^7.0.0"
  },
  "devDependencies": {
    "@types/archiver": "^7.0.0",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "esbuild": "^0.27.4",
    "tsx": "^4.19.0"
  }
}
